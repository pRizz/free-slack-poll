{
  "name": "free-slack-poll",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Production-ready Slack poll app for private/internal distribution.",
  "engines": {
    "node": ">=22.0.0",
    "bun": ">=1.3.0"
  },
  "scripts": {
    "dev": "bunx tsx watch src/app.ts",
    "build": "bunx tsc -p tsconfig.build.json",
    "start": "node dist/app.js",
    "preflight": "bunx tsx src/scripts/preflight.ts",
    "typecheck": "bunx tsc --noEmit -p tsconfig.json",
    "lint": "bunx @biomejs/biome lint .",
    "format": "bunx @biomejs/biome format --write .",
    "test": "bunx vitest run",
    "test:watch": "bunx vitest",
    "db:generate": "bunx drizzle-kit generate",
    "db:migrate": "bunx tsx src/db/migrate.ts",
    "docker:build": "docker build -t free-slack-poll:local .",
    "docker:smoke": "./scripts/docker-smoke.sh docker",
    "compose:config": "docker compose --env-file .env.compose.example config",
    "compose:smoke": "./scripts/docker-smoke.sh compose",
    "railway:doctor": "./scripts/railway-assist.sh doctor",
    "railway:bootstrap": "./scripts/railway-assist.sh bootstrap",
    "railway:deploy": "./scripts/railway-assist.sh deploy",
    "railway:status": "./scripts/railway-assist.sh status",
    "railway:logs": "./scripts/railway-assist.sh logs",
    "railway:vars:push": "./scripts/railway-assist.sh vars-push"
  },
  "dependencies": {
    "@slack/bolt": "^4.6.0",
    "dotenv": "^16.6.1",
    "drizzle-orm": "^0.44.5",
    "pg": "^8.16.3",
    "pino": "^9.9.0",
    "pino-pretty": "^13.1.2",
    "zod": "^4.1.11"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.2.4",
    "@types/node": "^24.5.2",
    "@types/pg": "^8.15.5",
    "drizzle-kit": "^0.31.5",
    "pg-mem": "^3.0.5",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2",
    "vitest": "^3.2.4"
  }
}
